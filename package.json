{
  "name": "@ait-co/polyfill",
  "version": "0.1.16",
  "description": "Polyfill so you can build Apps in Toss mini-apps with standard Web APIs (navigator.clipboard, navigator.geolocation, ...) that transparently route through the SDK at runtime",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./clipboard": {
      "import": {
        "types": "./dist/shims/clipboard.d.ts",
        "default": "./dist/shims/clipboard.js"
      },
      "require": {
        "types": "./dist/shims/clipboard.d.cts",
        "default": "./dist/shims/clipboard.cjs"
      }
    },
    "./geolocation": {
      "import": {
        "types": "./dist/shims/geolocation.d.ts",
        "default": "./dist/shims/geolocation.js"
      },
      "require": {
        "types": "./dist/shims/geolocation.d.cts",
        "default": "./dist/shims/geolocation.cjs"
      }
    },
    "./share": {
      "import": {
        "types": "./dist/shims/share.d.ts",
        "default": "./dist/shims/share.js"
      },
      "require": {
        "types": "./dist/shims/share.d.cts",
        "default": "./dist/shims/share.cjs"
      }
    },
    "./vibrate": {
      "import": {
        "types": "./dist/shims/vibrate.d.ts",
        "default": "./dist/shims/vibrate.js"
      },
      "require": {
        "types": "./dist/shims/vibrate.d.cts",
        "default": "./dist/shims/vibrate.cjs"
      }
    },
    "./vibrate-semantic": {
      "import": {
        "types": "./dist/shims/vibrate-semantic.d.ts",
        "default": "./dist/shims/vibrate-semantic.js"
      },
      "require": {
        "types": "./dist/shims/vibrate-semantic.d.cts",
        "default": "./dist/shims/vibrate-semantic.cjs"
      }
    },
    "./network": {
      "import": {
        "types": "./dist/shims/network.d.ts",
        "default": "./dist/shims/network.js"
      },
      "require": {
        "types": "./dist/shims/network.d.cts",
        "default": "./dist/shims/network.cjs"
      }
    },
    "./window-open": {
      "import": {
        "types": "./dist/shims/window-open.d.ts",
        "default": "./dist/shims/window-open.js"
      },
      "require": {
        "types": "./dist/shims/window-open.d.cts",
        "default": "./dist/shims/window-open.cjs"
      }
    },
    "./detect": {
      "import": {
        "types": "./dist/detect.d.ts",
        "default": "./dist/detect.js"
      },
      "require": {
        "types": "./dist/detect.d.cts",
        "default": "./dist/detect.cjs"
      }
    },
    "./auto": {
      "import": {
        "types": "./dist/auto.d.ts",
        "default": "./dist/auto.js"
      },
      "require": {
        "types": "./dist/auto.d.cts",
        "default": "./dist/auto.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/auto.js",
    "./dist/auto.cjs",
    "./dist/sentinel.js",
    "./dist/sentinel.cjs"
  ],
  "scripts": {
    "prebuild": "pnpm build:og",
    "build": "tsdown",
    "build:og": "TSX_TSCONFIG_PATH=scripts/tsconfig.json tsx scripts/build-og-image.tsx",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "peerDependencies": {
    "@apps-in-toss/web-framework": ">=2.4.0 <4.0.0"
  },
  "peerDependenciesMeta": {
    "@apps-in-toss/web-framework": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apps-in-toss/web-framework": "3.0.0-beta.3051978",
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tsdown": "^0.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "apps-in-toss",
    "toss",
    "mini-app",
    "polyfill",
    "web-api",
    "web-standard"
  ],
  "packageManager": "pnpm@10.33.0",
  "license": "BSD-3-Clause",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/apps-in-toss-community/polyfill"
  },
  "homepage": "https://www.npmjs.com/package/@ait-co/polyfill",
  "bugs": {
    "url": "https://github.com/apps-in-toss-community/polyfill/issues"
  }
}
